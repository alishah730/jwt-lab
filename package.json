{
  "name": "jwt-lab",
  "version": "0.0.9",
  "description": "jwt-lab – A fast, secure, beautiful JWT CLI tool and MCP server for developers & AI agents. Encode, decode, verify, inspect, audit, and generate keys for JSON Web Tokens.",
  "bin": {
    "jwt": "dist/cli.js"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "homepage": "https://github.com/alishah730/jwt-lab#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alishah730/jwt-lab.git"
  },
  "bugs": {
    "url": "https://github.com/alishah730/jwt-lab/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "jwt",
    "jwt-cli",
    "jwt-tool",
    "jwt-inspector",
    "jwt-decoder",
    "jwt-encoder",
    "jwt-verifier",
    "jwt-debugger",
    "jwt-audit",
    "jwt-linter",
    "jwt-keygen",
    "json-web-token",
    "token",
    "mcp-server",
    "mcp",
    "model-context-protocol",
    "jwt-mcp",
    "cli",
    "security",
    "authentication",
    "jose",
    "jws",
    "jwe",
    "jwk",
    "jwks",
    "oauth",
    "openid",
    "ai-agent",
    "llm-tool"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "lint": "eslint src",
    "mcp:serve": "node dist/mcp.js",
    "dev:mcp": "tsup --watch & node --watch dist/mcp.js",
    "changeset": "changeset",
    "optimize": "socket optimize"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "gradient-string": "^3.0.0",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.6.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^25.5.2",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "eslint": "^10.2.0",
    "execa": "^9.6.1",
    "fast-check": "^4.6.0",
    "prettier": "^3.8.1",
    "socket": "^1.1.78",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "is-interactive": "npm:@socketregistry/is-interactive@^1",
    "is-unicode-supported": "npm:@socketregistry/is-unicode-supported@^1",
    "object-assign": "npm:@socketregistry/object-assign@^1",
    "safer-buffer": "npm:@socketregistry/safer-buffer@^1"
  },
  "resolutions": {
    "is-interactive": "npm:@socketregistry/is-interactive@^1",
    "is-unicode-supported": "npm:@socketregistry/is-unicode-supported@^1",
    "object-assign": "npm:@socketregistry/object-assign@^1",
    "safer-buffer": "npm:@socketregistry/safer-buffer@^1"
  },
  "type": "module"
}
